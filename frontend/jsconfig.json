{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./*"
            ],
            "@/components/*": [
                "./src/components/*",
                "./components/*"
            ],
            "@/context/*": [
                "./src/context/*",
                "./context/*"
            ],
            "@/hooks/*": [
                "./src/hooks/*",
                "./hooks/*"
            ],
            "@/services/*": [
                "./src/services/*",
                "./services/*"
            ],
            "@/lib/*": [
                "./src/lib/*",
                "./lib/*"
            ],
            "@/constants/*": [
                "./constants/*",
                "./src/constants/*"
            ]
        }
    }
}