{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./*"
            ],
            "@/components/*": [
                "./src/components/*",
                "./components/*"
            ],
            "@/context/*": [
                "./src/context/*"
            ],
            "@/hooks/*": [
                "./src/hooks/*"
            ],
            "@/services/*": [
                "./src/services/*"
            ],
            "@/lib/*": [
                "./src/lib/*",
                "./lib/*"
            ],
            "@/constants/*": [
                "./constants/*",
                "./src/constants/*"
            ]
        }
    }
}
