# Supabase client configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API
VITE_API_BASE_URL=http://localhost:8000

# Skill names used by the application (tracking/documentation only)
VITE_APP_SKILLS=document-formatter,resume-formatter,ocr-document-processor,ui-ux-pro-max,documentation-templates
# Skill links used by the application (tracking/documentation only)
VITE_APP_SKILLS_LINKS=https://github.com/ntaksh42/agents;https://github.com/paramchoudhary/resumeskills;https://github.com/dkyazzentwatwa/chatgpt-skills;https://github.com/nextlevelbuilder/ui-ux-pro-max-skill;https://github.com/sickn33/antigravity-awesome-skills
# Skill install commands (tracking/documentation only)
VITE_APP_SKILLS_ADD_COMMAND_DOCUMENT_FORMATTER=npx skills add https://github.com/ntaksh42/agents --skill "document-formatter"
VITE_APP_SKILLS_ADD_COMMAND_RESUME_FORMATTER=npx skills add https://github.com/paramchoudhary/resumeskills --skill "Resume Formatter"
VITE_APP_SKILLS_ADD_COMMAND_OCR_DOCUMENT_PROCESSOR=npx skills add https://github.com/dkyazzentwatwa/chatgpt-skills --skill "ocr-document-processor"
VITE_APP_SKILLS_ADD_COMMAND_UI_UX_PRO_MAX=npx skills add https://github.com/nextlevelbuilder/ui-ux-pro-max-skill --skill "ui-ux-pro-max"
VITE_APP_SKILLS_ADD_COMMAND_DOCUMENTATION_TEMPLATES=npx skills add https://github.com/sickn33/antigravity-awesome-skills --skill "documentation-templates"

# Playwright e2e (optional override)
PLAYWRIGHT_BASE_URL=http://127.0.0.1:4173
