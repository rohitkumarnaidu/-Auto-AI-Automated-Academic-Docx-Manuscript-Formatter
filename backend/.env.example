# Supabase (mock values for CI)
SUPABASE_URL=https://mock.supabase.co
SUPABASE_ANON_KEY=mock-key
SUPABASE_JWKS_URL=https://mock.supabase.co/auth/v1/keys
SUPABASE_JWT_SECRET=mock-secret
SUPABASE_SERVICE_ROLE_KEY=mock-service-role
SUPABASE_DB_URL=postgresql://mock

# Security
ALGORITHM=HS256
CORS_ORIGINS=http://localhost:5173
SIGNED_URL_SECRET=mock-secret

# Billing
STRIPE_API_KEY=mock-stripe
STRIPE_WEBHOOK_SECRET=mock-webhook

# Upload Limits
MAX_FILE_SIZE=52428800
MAX_BATCH_FILES=10
UPLOADS_PER_MINUTE=10

# Deployment
FORCE_HTTPS=false
GLOBAL_RATE_LIMIT_PER_MINUTE=120
DEBUG=true
ENABLE_STRUCTURED_LOGGING=true

# Enhancement Layer
ENHANCEMENTS_ENABLED=false
ENHANCEMENT_QUEUE_ENABLED=false
ENHANCEMENT_QUEUE_PROVIDER=auto
ENHANCEMENT_QUEUE_MIN_SECONDS=5
ENHANCEMENT_OCR_ENABLED=false
ENHANCEMENT_OCR_BACKENDS=basic
ENHANCEMENT_KEYWORD_ENABLED=false
ENHANCEMENT_KEYWORD_BACKENDS=keyllm,basic

# Template
DEFAULT_TEMPLATE=none

# Confidence Thresholds
HEADING_STYLE_THRESHOLD=0.4
HEADING_FALLBACK_CONFIDENCE=0.45
HEURISTIC_CONFIDENCE_HIGH=0.95
HEURISTIC_CONFIDENCE_MEDIUM=0.9
HEURISTIC_CONFIDENCE_LOW=0.5

# External Tools
LIBREOFFICE_PATH=/usr/bin/soffice

# Retention / paths
ENABLE_FILE_CLEANUP=true
RETENTION_DAYS=30
GENERATED_OUTPUT_DIR=generated_outputs

# GROBID / LLM / AV
GROBID_URL=https://mock.hf.space
GROBID_URLS=https://mock-grobid-primary.hf.space,https://mock-grobid-shadow.hf.space
GROBID_HEALTH_PATH=/api/isalive
GROBID_BASE_URL=https://mock.hf.space
GROBID_TIMEOUT=60
GROBID_MAX_RETRIES=3
GROBID_ENABLED=true
DOCLING_API_URL=https://mock-docling-primary.hf.space
DOCLING_URL=https://mock-docling-primary.hf.space
DOCLING_URLS=https://mock-docling-primary.hf.space,https://mock-docling-shadow.hf.space
DOCX_CONVERTER_URL=https://mock-docx-primary.hf.space
DOCX_CONVERTER_URLS=https://mock-docx-primary.hf.space,https://mock-docx-shadow.hf.space
OCR_SERVICE_URL=https://mock-ocr-primary.hf.space
OCR_URL=https://mock-ocr-primary.hf.space
OCR_URLS=https://mock-ocr-primary.hf.space,https://mock-ocr-shadow.hf.space
NOUGAT_URL=https://mock-nougat-primary.hf.space
NOUGAT_URLS=https://mock-nougat-primary.hf.space,https://mock-nougat-shadow.hf.space
SCIBERT_URL=https://mock-scibert-primary.hf.space
SCIBERT_URLS=https://mock-scibert-primary.hf.space,https://mock-scibert-shadow.hf.space
DOCLING_HEALTH_PATH=/
DOCX_CONVERTER_HEALTH_PATH=/
OCR_HEALTH_PATH=/
NOUGAT_HEALTH_PATH=/
SCIBERT_HEALTH_PATH=/
USE_DOCLING_FALLBACK=false
PYMUPDF_FALLBACK=true

OLLAMA_URL=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

GROQ_API_KEY=mock
GROQ_MODEL=llama3-8b-8192
GROQ_API_BASE=https://api.groq.com/openai/v1
LLM_PROVIDER_TIMEOUT_SECONDS=15
EXTERNAL_CIRCUIT_BREAKER_ENABLED=true
EXTERNAL_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
EXTERNAL_CIRCUIT_BREAKER_RESET_SECONDS=60

NVIDIA_API_KEY=mock
NVIDIA_MODEL=mock
OPENAI_API_KEY=mock
ANTHROPIC_API_KEY=mock
OPENROUTER_API_KEY=mock
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Redis / celery / integrations
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CROSSREF_MAILTO=test@example.com

# Cache TTLs
LLM_CACHE_TTL_SECONDS=3600
READINESS_CACHE_TTL_SECONDS=15
HEALTH_CACHE_TTL_SECONDS=15
CSL_SEARCH_CACHE_TTL_SECONDS=300
CSL_FETCH_CACHE_TTL_SECONDS=1800
GENERATOR_SESSION_CACHE_TTL_SECONDS=2.0
GENERATOR_MESSAGES_CACHE_TTL_SECONDS=1.0
GENERATOR_SESSION_LIST_CACHE_TTL_SECONDS=3.0
GENERATOR_DOCUMENT_CACHE_TTL_SECONDS=2.0
DOCUMENT_STATUS_CACHE_TTL_SECONDS=1.0

# Pipeline tuning / feature toggles
PIPELINE_GROBID_TIMEOUT_SECONDS=25
PIPELINE_DOCLING_TIMEOUT_SECONDS=25
PIPELINE_REASONING_TIMEOUT_SECONDS=25
PIPELINE_SEMANTIC_TIMEOUT_SECONDS=25
PIPELINE_ACQUIRE_TIMEOUT_SECONDS=30.0
PIPELINE_DOCLING_SKIP_DIGITAL_PDF=true
PIPELINE_DOCLING_FORCE=false
ENABLE_NOUGAT_PARSER=false
ENABLE_NVIDIA_REASONER=false
USE_SCIBERT_CLASSIFICATION=false
SCIBERT_AUTO_ENABLE_FROM_BENCHMARK=true
SCIBERT_MIN_BENCHMARK_F1=0.85
SCIBERT_BENCHMARK_STATE_PATH=.metrics/scibert_benchmark_state.json
LOW_MEMORY_MODE=true
PRELOAD_AI_MODELS=false
RAG_USE_TRANSFORMERS=false
DEFAULT_FAST_MODE=true
CROSSREF_MAX_WORKERS=4
VLLM_ADOPTION_ENABLED=true
VLLM_TARGET_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
VLLM_TARGET_GPU=L4 24GB
VLLM_REQUESTS_PER_HOUR_THRESHOLD=2000
VLLM_DAILY_TOKENS_THRESHOLD=5000000
