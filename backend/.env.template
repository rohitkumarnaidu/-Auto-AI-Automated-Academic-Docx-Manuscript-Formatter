# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_DB_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_ANON_KEY=your-anon-key-here
# Service role JWT - used by the server-side supabase-py client (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# JWT secret used for verifying user tokens (get from Supabase Dashboard -> Settings -> API -> JWT Secret)
SUPABASE_JWT_SECRET=your-jwt-secret-here
# Frontend origins allowed by backend CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
ALGORITHM=HS256
SIGNED_URL_SECRET=change-me
DEBUG=true
GLOBAL_RATE_LIMIT_PER_MINUTE=120

DEEPSEEK_API_KEY=your-deepseek-api-key-here
HF_TOKEN=your-huggingface-token-here
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Template Configuration
DEFAULT_TEMPLATE=none  # Options: none, ieee, springer, apa

# Confidence Thresholds (0.0 - 1.0)
HEADING_STYLE_THRESHOLD=0.4
HEADING_FALLBACK_CONFIDENCE=0.45
HEURISTIC_CONFIDENCE_HIGH=0.95
HEURISTIC_CONFIDENCE_MEDIUM=0.9
HEURISTIC_CONFIDENCE_LOW=0.5

# External Tools
LIBREOFFICE_PATH=C:/Program Files/LibreOffice/program/soffice.exe

NVIDIA_API_KEY=your-nvidia-api-key-here
NVIDIA_MODEL=nvidia_nim/meta/llama-3.3-70b-instruct
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# GROBID Configuration
GROBID_URL=https://your-grobid-primary.hf.space
GROBID_URLS=https://your-grobid-primary.hf.space,https://your-grobid-shadow.hf.space
GROBID_HEALTH_PATH=/api/isalive
GROBID_BASE_URL=https://your-grobid-primary.hf.space
GROBID_TIMEOUT=30
GROBID_MAX_RETRIES=3
GROBID_ENABLED=true
DOCLING_API_URL=https://your-docling-primary.hf.space
DOCLING_URL=https://your-docling-primary.hf.space
DOCLING_URLS=https://your-docling-primary.hf.space,https://your-docling-shadow.hf.space
DOCX_CONVERTER_URL=https://your-docx-primary.hf.space
DOCX_CONVERTER_URLS=https://your-docx-primary.hf.space,https://your-docx-shadow.hf.space
OCR_SERVICE_URL=https://your-ocr-primary.hf.space
OCR_URL=https://your-ocr-primary.hf.space
OCR_URLS=https://your-ocr-primary.hf.space,https://your-ocr-shadow.hf.space
NOUGAT_URL=https://your-nougat-primary.hf.space
NOUGAT_URLS=https://your-nougat-primary.hf.space,https://your-nougat-shadow.hf.space
SCIBERT_URL=https://your-scibert-primary.hf.space
SCIBERT_URLS=https://your-scibert-primary.hf.space,https://your-scibert-shadow.hf.space
DOCLING_HEALTH_PATH=/
DOCX_CONVERTER_HEALTH_PATH=/
OCR_HEALTH_PATH=/
NOUGAT_HEALTH_PATH=/
SCIBERT_HEALTH_PATH=/
USE_DOCLING_FALLBACK=true
PYMUPDF_FALLBACK=true

# Ollama (optional local model serving)
OLLAMA_URL=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
GROQ_API_KEY=
GROQ_MODEL=groq/llama-3.3-70b-versatile
GROQ_API_BASE=https://api.groq.com/openai/v1
LLM_PROVIDER_TIMEOUT_SECONDS=15
EXTERNAL_CIRCUIT_BREAKER_ENABLED=true
EXTERNAL_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
EXTERNAL_CIRCUIT_BREAKER_RESET_SECONDS=60

# Redis (optional for local dev)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CROSSREF_MAILTO=email@gmail.com
LLM_CACHE_TTL_SECONDS=3600
READINESS_CACHE_TTL_SECONDS=15
HEALTH_CACHE_TTL_SECONDS=15
CSL_SEARCH_CACHE_TTL_SECONDS=300
CSL_FETCH_CACHE_TTL_SECONDS=1800
GENERATOR_SESSION_CACHE_TTL_SECONDS=2
GENERATOR_MESSAGES_CACHE_TTL_SECONDS=1
GENERATOR_SESSION_LIST_CACHE_TTL_SECONDS=3
GENERATOR_DOCUMENT_CACHE_TTL_SECONDS=2
DOCUMENT_STATUS_CACHE_TTL_SECONDS=1

# Optional Enhancement Layer (fallback-first; safe to disable)
ENHANCEMENTS_ENABLED=true
ENHANCEMENT_QUEUE_ENABLED=false
ENHANCEMENT_QUEUE_PROVIDER=auto      # auto | local | celery
ENHANCEMENT_QUEUE_MIN_SECONDS=5
ENHANCEMENT_OCR_ENABLED=true
ENHANCEMENT_OCR_BACKENDS=tesseract,paddle,surya
ENHANCEMENT_KEYWORD_ENABLED=true
ENHANCEMENT_KEYWORD_BACKENDS=keyllm,keybert,yake,basic

# Pipeline timeout/performance tuning
PIPELINE_GROBID_TIMEOUT_SECONDS=25
PIPELINE_DOCLING_TIMEOUT_SECONDS=25
PIPELINE_REASONING_TIMEOUT_SECONDS=28
PIPELINE_SEMANTIC_TIMEOUT_SECONDS=25
PIPELINE_ACQUIRE_TIMEOUT_SECONDS=30
# Skip Docling pass for digital-native PDFs (faster); keep true for local speed.
PIPELINE_DOCLING_SKIP_DIGITAL_PDF=true
# Set true only when you explicitly want Docling on every PDF.
PIPELINE_DOCLING_FORCE=false
# Enable Nougat OCR parser as optional fallback (heavy; keep false unless needed).
ENABLE_NOUGAT_PARSER=false
# Toggle NVIDIA reasoning tier for semantic instruction generation.
ENABLE_NVIDIA_REASONER=true
USE_SCIBERT_CLASSIFICATION=false
SCIBERT_AUTO_ENABLE_FROM_BENCHMARK=true
SCIBERT_MIN_BENCHMARK_F1=0.85
SCIBERT_BENCHMARK_STATE_PATH=.metrics/scibert_benchmark_state.json
# Low-memory deployment profile (recommended on Render free 512MB).
LOW_MEMORY_MODE=true
PRELOAD_AI_MODELS=false
RAG_USE_TRANSFORMERS=false
DEFAULT_FAST_MODE=false
CROSSREF_MAX_WORKERS=4
VLLM_ADOPTION_ENABLED=true
VLLM_TARGET_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
VLLM_TARGET_GPU=L4 24GB
VLLM_REQUESTS_PER_HOUR_THRESHOLD=2000
VLLM_DAILY_TOKENS_THRESHOLD=5000000

# Application Settings
MAX_FILE_SIZE=52428800 # 50MB
MAX_BATCH_FILES=10
FORCE_HTTPS=False
ENABLE_FILE_CLEANUP=true
RETENTION_DAYS=30
ENABLE_STRUCTURED_LOGGING=true
UPLOADS_PER_MINUTE=10
GENERATED_OUTPUT_DIR=generated_outputs

# Skill names used by the application (tracking/documentation only)
APP_SKILLS=document-formatter,resume-formatter,ocr-document-processor,ui-ux-pro-max,documentation-templates
# Skill links used by the application (tracking/documentation only)
APP_SKILLS_LINKS=https://github.com/ntaksh42/agents;https://github.com/paramchoudhary/resumeskills;https://github.com/dkyazzentwatwa/chatgpt-skills;https://github.com/nextlevelbuilder/ui-ux-pro-max-skill;https://github.com/sickn33/antigravity-awesome-skills
# Skill install commands (tracking/documentation only)
APP_SKILLS_ADD_COMMAND_DOCUMENT_FORMATTER=npx skills add https://github.com/ntaksh42/agents --skill "document-formatter"
APP_SKILLS_ADD_COMMAND_RESUME_FORMATTER=npx skills add https://github.com/paramchoudhary/resumeskills --skill "Resume Formatter"
APP_SKILLS_ADD_COMMAND_OCR_DOCUMENT_PROCESSOR=npx skills add https://github.com/dkyazzentwatwa/chatgpt-skills --skill "ocr-document-processor"
APP_SKILLS_ADD_COMMAND_UI_UX_PRO_MAX=npx skills add https://github.com/nextlevelbuilder/ui-ux-pro-max-skill --skill "ui-ux-pro-max"
APP_SKILLS_ADD_COMMAND_DOCUMENTATION_TEMPLATES=npx skills add https://github.com/sickn33/antigravity-awesome-skills --skill "documentation-templates"

# Auto-discovered keys without defaults
GROBID_HOST=
GROBID_PORT=
PANDOC_PATH=
SCIBERT_BENCHMARK_MODEL=
